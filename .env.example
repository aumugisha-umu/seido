# 🔧 SEIDO - Environment Variables Template
# Copy this file to .env.local and fill in your actual values

# ================================
# 🗄️ SUPABASE DATABASE
# ================================
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ================================
# 🔐 AUTHENTICATION
# ================================
# Set to false in production, true for local development without Supabase
NEXT_PUBLIC_USE_MOCK_AUTH=false

# ================================
# 📧 RESEND EMAIL SERVICE
# ================================
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=re_YOUR_API_KEY_HERE
# Must be a verified domain in Resend (use onboarding@resend.dev for dev)
RESEND_FROM_EMAIL="SEIDO <noreply@yourverifieddomain.com>"

# Admin notification recipients (comma-separated, platform owner alerts)
ADMIN_NOTIFICATION_EMAILS=admin@yourdomain.com

# ================================
# 📨 EMAIL REPLY SYSTEM (Inbound)
# ================================
# Allows tenants/providers to reply directly to notification emails
# Replies are automatically linked to the corresponding intervention

# Webhook signing secret from Resend Dashboard → Webhooks
# Used to verify webhook authenticity (starts with whsec_)
# ⚠️ NOTE: This is specifically for INBOUND webhooks (email replies)
RESEND_INBOUND_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE

# Domain configured in Resend for receiving emails (MX records required)
# Default: reply.seido-app.com
RESEND_INBOUND_DOMAIN=reply.seido-app.com

# HMAC secret key for signing reply-to addresses (prevents tampering)
# Generate with: openssl rand -hex 32
REPLY_TO_SECRET=your_32_byte_hex_secret_here

# ================================
# 🏢 CBEAPI - Belgian Company Database
# ================================
# Free API for searching Belgian companies (KBO/BCE)
# Sign up: https://cbeapi.be/en/register
# Free tier: 2500 requests/day
# Documentation: https://cbeapi.be/en/docs
CBEAPI_URL=https://cbeapi.be/api/v1
CBEAPI_KEY=your_cbeapi_key_here
# Example format: cbeapi_abc123def456ghi789jkl012mno345pqr678stu

# ================================
# 🔄 REDIS - Cache & Rate Limiting
# ================================
# Optional but recommended for production (caching company lookups, rate limiting)
# Free tier: Upstash Redis - https://console.upstash.com/
# 10,000 commands/day free
REDIS_URL=rediss://default:xxxxx@xxxxx.upstash.io:6379

# ================================
# 💳 STRIPE SUBSCRIPTION BILLING
# ================================
# Get keys from: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Webhook signing secret
# Dev: from `stripe listen --forward-to localhost:3000/api/stripe/webhook`
# Prod: from Dashboard > Developers > Webhooks > endpoint signing secret
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Price IDs from Dashboard > Products > SEIDO Subscription
STRIPE_PRICE_ANNUAL=price_xxx
STRIPE_PRICE_MONTHLY=price_xxx

# ================================
# ⏰ CRON JOBS AUTHENTICATION
# ================================
# Used by Vercel CRON to authenticate scheduled jobs
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=xxx

# ================================
# 🌍 APPLICATION URL
# ================================
# ⚠️ CRITICAL: This MUST match your deployment URL
# Development: http://localhost:3000
# Production: https://your-app.vercel.app or your custom domain
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ================================
# 📝 LOGGING
# ================================
# Levels: trace, debug, info, warn, error, fatal
LOG_LEVEL=debug

# ================================
# 📧 SUPPORT EMAIL (Optional)
# ================================
# Used in email templates for user support contact
SUPPORT_EMAIL=support@yourapp.com

# ================================
# 📣 FRILL FEEDBACK WIDGET (Optional)
# ================================
# Get your keys from: https://frill.co/settings/widget
# Used for collecting user feedback and feature requests
NEXT_PUBLIC_FRILL_CONTAINER_KEY=container_YOUR_KEY_HERE
NEXT_PUBLIC_FRILL_WIDGET_KEY=widget_YOUR_KEY_HERE

# ================================
# 🗺️ GOOGLE MAPS PLATFORM
# ================================
# Get your API key from: https://console.cloud.google.com/google/maps-apis/credentials
# Required APIs: Maps JavaScript API, Places API (New)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Map ID for Advanced Markers (create in Google Cloud Console → Map Management)
NEXT_PUBLIC_GOOGLE_MAP_ID=your_map_id_here

# ================================
# 🤖 AI WHATSAPP AGENT
# ================================
# Provisioning mode: manual (dev — uses DEV_* values) | auto (prod — Twilio API provisioning)
AI_WHATSAPP_PROVISIONING=manual
# Dev only: WhatsApp-enabled phone number for manual provisioning mode
DEV_WHATSAPP_PHONE_NUMBER=+32460257659

# Shared WhatsApp number — single number for all teams (Twilio WhatsApp Sender)
SEIDO_WHATSAPP_NUMBER=+32460257659

# Anthropic (Claude Haiku 4.5 — conversational AI engine)
# Get from: https://console.anthropic.com → Settings → API Keys
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxx

# Meta WhatsApp Business API
# Access token: Business Manager → System Users → seido-whatsapp-bot → Generate Token (permanent)
# ⚠️ Tokens from Developer Portal "Configuration de l'API" page are TEMPORARY (24h)
META_WHATSAPP_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxx
# WABA ID: Developer Portal → your app → WhatsApp → "Configuration de l'API" → "ID du compte WhatsApp Business"
META_WHATSAPP_BUSINESS_ID=123456789012345

# Stripe AI Add-on Prices (from Dashboard > Products > Assistant WhatsApp IA)
# Monthly
STRIPE_PRICE_AI_SOLO=price_xxx
STRIPE_PRICE_AI_EQUIPE=price_xxx
STRIPE_PRICE_AI_AGENCE=price_xxx
# Annual (same products, yearly billing interval)
STRIPE_PRICE_AI_SOLO_ANNUAL=price_xxx
STRIPE_PRICE_AI_EQUIPE_ANNUAL=price_xxx
STRIPE_PRICE_AI_AGENCE_ANNUAL=price_xxx

# ================================
# 📱 TWILIO (Phone numbers + WhatsApp messaging)
# ================================
# Twilio credentials: https://console.twilio.com → Account Info
# Used for: purchasing phone numbers, sending/receiving WhatsApp messages, webhook signature validation
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here


# ================================
# 📊 MICROSOFT CLARITY (Analytics)
# ================================
# Get your Project ID from: https://clarity.microsoft.com → Settings → Overview
# Dev and Prod should use separate projects for clean data
NEXT_PUBLIC_CLARITY_PROJECT_ID=your_clarity_project_id_here
